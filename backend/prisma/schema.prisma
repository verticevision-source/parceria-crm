generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum BulkMessageStatus {
  DRAFT
  RUNNING
  DONE
  FAILED
}

enum SessionStatus {
  CONNECTED
  DISCONNECTED
  WAITING_QR
  ERROR
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum LeadStatus {
  OPEN
  WON
  LOST
}

enum MessageDirection {
  IN
  OUT
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  VIDEO
  LOCATION
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  avatarUrl    String?  @db.Text
  fichaLink    String?  @db.Text  // link da ficha do vendedor no Parceria Financeira
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  whatsappSessions WhatsAppSession[]
  conversations    Conversation[]
  messages         Message[]
  contacts         Contact[]
  leads            Lead[]            @relation("ResponsibleUser")
  crmNotes         CRMNote[]
  auditLogs        AuditLog[]
  quickReplies     QuickReply[]
  rouletteAgent    RouletteAgent?
  rouletteLogs     RouletteLog[]
  crmBoardMembers  CRMBoardMember[]
  bulkMessages     BulkMessage[]
  internalGroups   InternalGroupMember[]
  internalMessages InternalMessage[]
  callLogs         CallLog[]
  aiEnabled        Boolean  @default(false)  // admin libera assistente de IA p/ este usuário

  @@map("users")
}

model WhatsAppSession {
  id             String        @id @default(uuid())
  userId         String
  name           String?
  phoneNumber    String?
  status         SessionStatus @default(WAITING_QR)
  qrCode         String?       @db.Text
  provider       String        @default("mock")
  connectedAt    DateTime?
  disconnectedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  messages      Message[]

  @@map("whatsapp_sessions")
}

model Contact {
  id             String   @id @default(uuid())
  userId         String
  name           String
  phone          String
  city           String?
  documentNumber String?
  notes          String?  @db.Text
  avatarUrl      String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations    Conversation[]
  messages         Message[]
  leads            Lead[]
  tags             ContactTag[]
  bulkRecipients   BulkMessageRecipient[]
  callLogs         CallLog[]

  @@map("contacts")
}

model Conversation {
  id                String             @id @default(uuid())
  userId            String
  whatsappSessionId String
  contactId         String?
  leadId            String?
  status            ConversationStatus @default(OPEN)
  lastMessage       String?
  lastMessageAt     DateTime?
  unreadCount       Int                @default(0)
  aiAuto            Boolean            @default(false)  // IA responde automaticamente nesta conversa
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappSession WhatsAppSession   @relation(fields: [whatsappSessionId], references: [id])
  contact         Contact?          @relation(fields: [contactId], references: [id])
  lead            Lead?             @relation(fields: [leadId], references: [id])
  messages        Message[]
  tags            ConversationTag[]

  @@map("conversations")
}

model Message {
  id                String           @id @default(uuid())
  conversationId    String
  userId            String
  whatsappSessionId String
  contactId         String?
  direction         MessageDirection
  type              MessageType      @default(TEXT)
  textBody          String?          @db.Text
  mediaUrl          String?
  latitude          Float?
  longitude         Float?
  externalMessageId String?
  sentAt            DateTime?
  createdAt         DateTime         @default(now())

  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id])
  whatsappSession WhatsAppSession @relation(fields: [whatsappSessionId], references: [id])
  contact         Contact?        @relation(fields: [contactId], references: [id])

  @@map("messages")
}

model PipelineStage {
  id        String   @id @default(uuid())
  name      String
  order     Int
  color     String   @default("#6366f1")
  boardId   String?  // null = estágio global (legado)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board CRMBoard? @relation(fields: [boardId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@map("pipeline_stages")
}

model Lead {
  id                String     @id @default(uuid())
  contactId         String
  responsibleUserId String
  pipelineStageId   String?
  campaignId        String?
  boardId           String?    // CRM board ao qual pertence
  status            LeadStatus @default(OPEN)
  source            String?
  value             Float?
  notes             String?    @db.Text
  tags              String?    @db.Text  // JSON array de tags
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  lastInteractionAt DateTime?

  contact         Contact        @relation(fields: [contactId], references: [id])
  responsibleUser User           @relation("ResponsibleUser", fields: [responsibleUserId], references: [id])
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])
  campaign        Campaign?      @relation(fields: [campaignId], references: [id])
  board           CRMBoard?      @relation(fields: [boardId], references: [id])
  conversations   Conversation[]
  crmNotes        CRMNote[]
  rouletteLogs    RouletteLog[]
  callLogs        CallLog[]

  @@map("leads")
}

model CallLog {
  id          String   @id @default(uuid())
  contactId   String
  userId      String   // quem registrou a ligação
  leadId      String?
  phone       String
  direction   String   @default("OUT")       // OUT = ligou, IN = recebeu
  outcome     String   @default("completed")  // completed, no_answer, busy, voicemail, scheduled
  durationSec Int      @default(0)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([userId])
  @@map("call_logs")
}

model CRMNote {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("crm_notes")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  contacts          ContactTag[]
  conversationTags  ConversationTag[]
  autoTagRules      AutoTagRule[]

  @@map("tags")
}

// Regras de auto-tag: quando uma mensagem recebida contém a palavra-chave,
// a tag é aplicada automaticamente na conversa
model AutoTagRule {
  id        String   @id @default(uuid())
  keyword   String
  tagId     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("auto_tag_rules")
}

model ContactTag {
  id        String @id @default(uuid())
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@map("contact_tags")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// Quick replies (respostas rápidas)
model QuickReply {
  id        String   @id @default(uuid())
  userId    String
  isGlobal  Boolean  @default(false)
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quick_replies")
}

// Tags for conversations
model ConversationTag {
  id             String @id @default(uuid())
  conversationId String
  tagId          String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([conversationId, tagId])
  @@map("conversation_tags")
}

// Custom fields definition (admin-defined)
model CustomField {
  id         String   @id @default(uuid())
  name       String
  fieldKey   String   @unique
  type       String   // TEXT, NUMBER, DATE, SELECT, BOOLEAN
  entity     String   // CONTACT, LEAD
  options    String?  @db.Text
  isRequired Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  values CustomFieldValue[]

  @@map("custom_fields")
}

// ── Roleta de Leads ───────────────────────────────────────────────────────────

// Time regional (ex: Sorocaba, Rio Preto)
model RouletteTeam {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents    RouletteAgentTeam[]
  campaigns Campaign[]

  @@map("roulette_teams")
}

// Configuração de cada agente na roleta
model RouletteAgent {
  id          String    @id @default(uuid())
  userId      String    @unique
  isActive    Boolean   @default(false)
  weight      Int       @default(1)
  leadsToday  Int       @default(0)
  leadsTotal  Int       @default(0)
  lastLeadAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  teams RouletteAgentTeam[]  // many-to-many com times

  @@map("roulette_agents")
}

// Relação many-to-many: agente pode estar em vários times
model RouletteAgentTeam {
  id      String @id @default(uuid())
  agentId String
  teamId  String

  agent RouletteAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  team  RouletteTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([agentId, teamId])
  @@map("roulette_agent_teams")
}

// Campanha de origem dos leads
model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  source      String?  // whatsapp, landing_page, facebook, instagram, etc.
  teamId      String?                      // time que recebe os leads desta campanha
  isActive    Boolean  @default(true)
  leadsCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team         RouletteTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  leads        Lead[]
  rouletteLogs RouletteLog[]

  @@map("campaigns")
}

// Log de distribuições da roleta
model RouletteLog {
  id         String   @id @default(uuid())
  userId     String
  leadId     String?
  campaignId String?
  notes      String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  lead     Lead?     @relation(fields: [leadId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@map("roulette_logs")
}

// ── CRM Dinâmico ──────────────────────────────────────────────────────────────

// Boards de CRM (ex: Vendas, Gerente de Conta, Pós-Venda)
model CRMBoard {
  id          String   @id @default(uuid())
  name        String   // "Vendas", "Gerente de Conta"
  description String?
  color       String   @default("#6366f1")
  icon        String   @default("briefcase")  // lucide icon name
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages  PipelineStage[]
  leads   Lead[]
  members CRMBoardMember[]

  @@map("crm_boards")
}

// Usuários membros de um board
model CRMBoardMember {
  id      String @id @default(uuid())
  boardId String
  userId  String
  role    String @default("member")  // "member", "manager"

  board CRMBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@map("crm_board_members")
}

// ── Envio em Massa / Remarketing ──────────────────────────────────────────────

model BulkMessage {
  id          String            @id @default(uuid())
  name        String            // nome da campanha/ação
  message     String            @db.Text  // texto da mensagem
  createdById String
  status      BulkMessageStatus @default(DRAFT)
  // Filtros de alvo (JSON)
  filterType  String            // "tag", "stage", "board", "no_response", "campaign"
  filterValue String?           // valor do filtro (tagName, stageId, boardId, etc.)
  filterDays  Int?              // para "no_response": sem resposta há X dias
  totalCount  Int               @default(0)   // total de destinatários
  sentCount   Int               @default(0)   // enviados
  failedCount Int               @default(0)   // falhados
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  createdBy  User                   @relation(fields: [createdById], references: [id])
  recipients BulkMessageRecipient[]

  @@map("bulk_messages")
}

model BulkMessageRecipient {
  id            String   @id @default(uuid())
  bulkMessageId String
  contactId     String
  phone         String
  status        String   @default("pending")  // pending, sent, failed, replied
  sentAt        DateTime?
  repliedAt     DateTime?
  errorMessage  String?

  bulkMessage BulkMessage @relation(fields: [bulkMessageId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id])

  @@map("bulk_message_recipients")
}

model CustomFieldValue {
  id            String   @id @default(uuid())
  customFieldId String
  entityId      String
  value         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, entityId])
  @@map("custom_field_values")
}

// ── Construtor de Fluxo (Chatbot) ─────────────────────────────────────────────

model ChatFlow {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(false)
  nodes     Json     @default("[]")  // nós do React Flow
  edges     Json     @default("[]")  // conexões do React Flow
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_flows")
}

model ChatFlowSession {
  id             String    @id @default(uuid())
  flowId         String
  conversationId String    @unique
  contactId      String
  currentNodeId  String?
  status         String    @default("running")  // running | waiting | done
  lastReply      String?
  waitingSince   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("chat_flow_sessions")
}

// ── Números de WhatsApp (multi-número) ────────────────────────────────────────

model WhatsAppNumber {
  id             String   @id @default(uuid())
  label          String                      // apelido amigável ("Vendas SP", "Suporte")
  phoneNumberId  String   @unique             // Phone Number ID da Meta
  token          String                       // token de acesso desse número
  wabaId         String?                       // WhatsApp Business Account ID
  displayNumber  String?                       // ex: +55 15 99999-9999
  verifiedName   String?
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)      // número padrão para envios
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("whatsapp_numbers")
}

// ── Configuração de IA ────────────────────────────────────────────────────────

model AIConfig {
  id           String   @id @default("singleton")
  provider     String   @default("gemini")  // 'openai' | 'gemini'
  apiKey       String?
  model        String?                       // ex: gpt-4o-mini, gemini-1.5-flash
  systemPrompt String?  @db.Text             // instruções do negócio para a IA
  enabled      Boolean  @default(false)
  updatedAt    DateTime @updatedAt @default(now())

  @@map("ai_config")
}

// ── Chat Interno da Equipe ────────────────────────────────────────────────────

model InternalGroup {
  id          String   @id @default(uuid())
  name        String   // "Vendedores", "Gerentes de Conta"
  description String?
  color       String   @default("#6366f1")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  InternalGroupMember[]
  messages InternalMessage[]

  @@map("internal_groups")
}

model InternalGroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  lastReadAt DateTime?

  group InternalGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("internal_group_members")
}

model InternalMessage {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())

  group InternalGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("internal_messages")
}
